<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#f8f5f2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <!-- App Logo/Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧘 修心"
            android:textSize="64sp"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="修心 · 正念冥想"
            android:textSize="24sp"
            android:textColor="#5a4a42"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="静心凝神，安住当下"
            android:textSize="16sp"
            android:textColor="#888888"
            android:layout_marginBottom="60dp" />

        <!-- Config Warning -->
        <TextView
            android:id="@+id/configWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ 第三方登录尚未配置"
            android:textSize="14sp"
            android:textColor="#e74c3c"
            android:background="#fef0ed"
            android:padding="16dp"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:visibility="gone" />

        <!-- Google Login Button -->
        <Button
            android:id="@+id/btnGoogleLogin"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🔵 使用 Google 账号登录"
            android:textSize="16sp"
            android:textColor="#ffffff"
            android:background="@drawable/btn_google"
            android:layout_marginBottom="16dp" />

        <!-- WeChat Login Button -->
        <Button
            android:id="@+id/btnWeChatLogin"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="💚 使用微信登录"
            android:textSize="16sp"
            android:textColor="#ffffff"
            android:background="@drawable/btn_wechat"
            android:layout_marginBottom="16dp" />

        <!-- Email Login Button -->
        <Button
            android:id="@+id/btnEmailLogin"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="📧 使用邮箱验证码登录"
            android:textSize="16sp"
            android:textColor="#ffffff"
            android:background="@drawable/btn_email"
            android:layout_marginBottom="16dp" />

        <!-- Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#ddd" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  或  "
                android:textSize="14sp"
                android:textColor="#999"
                android:paddingHorizontal="16dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#ddd" />
        </LinearLayout>

        <!-- Skip Login -->
        <Button
            android:id="@+id/btnSkipLogin"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="先逛逛 (游客模式)"
            android:textSize="16sp"
            android:textColor="#8b7355"
            android:background="@drawable/button_secondary"
            android:layout_marginBottom="32dp" />

        <!-- Terms -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="登录即表示同意"
            android:textSize="12sp"
            android:textColor="#999"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="《用户协议》"
                android:textSize="12sp"
                android:textColor="#8b7355" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" 和 "
                android:textSize="12sp"
                android:textColor="#999" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="《隐私政策》"
                android:textSize="12sp"
                android:textColor="#8b7355" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
