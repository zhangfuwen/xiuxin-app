<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5f0eb"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="修心"
                android:textSize="40sp"
                android:textColor="#5a4a42"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="安住当下"
                android:textSize="16sp"
                android:textColor="#8b7d72"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Blessing Card -->
        <LinearLayout
            android:id="@+id/blessingCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="24dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="今日加持语"
                android:textSize="18sp"
                android:textColor="#5a4a42"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/blessingText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="17sp"
                android:textColor="#4a4a4a"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/blessingSource"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#999999"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/practice_background"
                android:padding="12dp">

                <TextView
                    android:id="@+id/blessingPractice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="#8b7355" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡 点击刷新加持语"
                android:textSize="12sp"
                android:textColor="#bbbbbb"
                android:layout_marginTop="12dp"
                android:layout_gravity="center_horizontal" />
        </LinearLayout>

        <!-- Breathing Exercise Card -->
        <LinearLayout
            android:id="@+id/breathingCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="24dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧘 呼吸练习"
                android:textSize="18sp"
                android:textColor="#5a4a42"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="观呼吸，安住当下"
                android:textSize="15sp"
                android:textColor="#666666"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/startBreathingBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="开始练习"
                android:textSize="16sp"
                android:background="@drawable/button_primary"
                android:textColor="#ffffff" />
        </LinearLayout>

        <!-- Meditation Timer Card -->
        <LinearLayout
            android:id="@+id/meditationCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="24dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱️ 冥想计时"
                android:textSize="18sp"
                android:textColor="#5a4a42"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="三种法门可选"
                android:textSize="15sp"
                android:textColor="#666666"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/startMeditationBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="选择法门"
                android:textSize="16sp"
                android:background="@drawable/button_primary"
                android:textColor="#ffffff" />
        </LinearLayout>

        <!-- Daily Practice Card -->
        <LinearLayout
            android:id="@+id/practiceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="24dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ 戒律打卡"
                android:textSize="18sp"
                android:textColor="#5a4a42"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="每日功课，精进不懈"
                android:textSize="15sp"
                android:textColor="#666666"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/startPracticeBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="今日打卡"
                android:textSize="16sp"
                android:background="@drawable/button_primary"
                android:textColor="#ffffff" />
        </LinearLayout>

        <!-- Stats Card -->
        <LinearLayout
            android:id="@+id/statsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="24dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 修习统计"
                android:textSize="18sp"
                android:textColor="#5a4a42"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/totalDaysText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textColor="#5a4a42"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="总天数"
                        android:textSize="13sp"
                        android:textColor="#999999"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/streakText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textColor="#8b7355"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="连续天数"
                        android:textSize="13sp"
                        android:textColor="#999999"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/meditationMinutesText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textColor="#6b8b73"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="冥想分钟"
                        android:textSize="13sp"
                        android:textColor="#999999"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="修心，从每一次呼吸开始 🙏"
            android:textSize="14sp"
            android:textColor="#bbbbbb"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp" />

    </LinearLayout>
</ScrollView>
