<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#f5f0eb">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@android:color/white"
        android:elevation="2dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/cancelBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="取消"
            android:textSize="14sp"
            style="@style/Widget.Material3.Button.TextButton" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="分享禅语"
            android:textSize="18sp"
            android:textColor="#5a4a42"
            android:textStyle="bold"
            android:gravity="center" />

        <Button
            android:id="@+id/publishBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="发布"
            android:textSize="14sp"
            android:paddingHorizontal="24dp"
            style="@style/Widget.Material3.Button" />
    </LinearLayout>

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Main text input - Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="禅语内容"
                    android:textSize="14sp"
                    android:textColor="#8b7d72"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:minLines="5"
                    android:gravity="top"
                    android:textSize="16sp"
                    android:textColor="#333"
                    android:background="@null"
                    android:hint="在此输入禅语、感悟或智慧..." />
            </LinearLayout>

            <!-- More Button -->
            <Button
                android:id="@+id/moreBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="更多"
                android:textSize="14sp"
                android:textColor="#8b7d72"
                android:background="@android:color/transparent"
                android:layout_marginBottom="16dp"
                style="@style/Widget.Material3.Button.TextButton" />

            <!-- Advanced Fields - Card (hidden by default) -->
            <LinearLayout
                android:id="@+id/advancedFieldsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="20dp"
                android:elevation="2dp"
                android:visibility="gone">

                <!-- Source -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="出处 / 来源"
                    android:textSize="14sp"
                    android:textColor="#8b7d72"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/sourceEdit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textSize="15sp"
                    android:background="@null"
                    android:hint="例如：《金刚经》、六祖慧能"
                    android:layout_marginBottom="20dp" />

                <!-- Practice -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="今日练习"
                    android:textSize="14sp"
                    android:textColor="#8b7d72"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/practiceEdit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:textSize="15sp"
                    android:gravity="top"
                    android:background="@null"
                    android:hint="分享一个相关的修行练习..."
                    android:layout_marginBottom="20dp" />

                <!-- Category -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="分类"
                    android:textSize="14sp"
                    android:textColor="#8b7d72"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/categoryEdit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textSize="15sp"
                    android:background="@null"
                    android:drawableEnd="@android:drawable/arrow_down_float"
                    android:hint="点击切换分类"
                    android:layout_marginBottom="20dp" />

                <!-- Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="你的名字"
                    android:textSize="14sp"
                    android:textColor="#8b7d72"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/nameEdit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textSize="15sp"
                    android:background="@null"
                    android:hint="如何称呼你？（可选，默认匿名）" />
            </LinearLayout>

            <!-- Bottom spacing -->
            <View
                android:layout_width="match_parent"
                android:layout_height="40dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
