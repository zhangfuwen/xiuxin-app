<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#f5f0eb">

    <!-- Top Section: Timer + Guide -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Timer -->
        <TextView
            android:id="@+id/meditationTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15:00"
            android:textSize="64sp"
            android:textColor="#8b7355"
            android:textStyle="bold"
            android:fontFamily="sans-serif-light"
            android:layout_marginBottom="16dp" />

        <!-- Selected Method Display + Select Button -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/meditationMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧘 选择法门开始修习"
                android:textSize="18sp"
                android:textColor="#5a4a42"
                android:textStyle="bold"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btnSelectMethodTop"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="选择"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/button_circle"
                android:textColor="#ffffff"
                android:paddingHorizontal="16dp" />
        </LinearLayout>

        <!-- Breathing Circle (for 呼吸法门 mode) -->
        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <View
                android:id="@+id/breathingCircleOuter"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/breathing_circle_outer"
                android:visibility="gone" />

            <View
                android:id="@+id/breathingCircle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/breathing_circle"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Guide Text -->
        <TextView
            android:id="@+id/meditationGuide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="请从下方列表选择一个法门开始修习"
            android:textSize="16sp"
            android:textColor="#666666"
            android:gravity="center"
            android:lineSpacingExtra="6dp"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="24dp" />

        <!-- Duration Controls with better contrast -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/method_card"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnDecrease"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="-"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@drawable/button_circle"
                android:textColor="#ffffff" />

            <TextView
                android:id="@+id/customDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15 分钟"
                android:textSize="18sp"
                android:textColor="#5a4a42"
                android:textStyle="bold"
                android:layout_marginHorizontal="24dp" />

            <Button
                android:id="@+id/btnIncrease"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="+"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@drawable/button_circle"
                android:textColor="#ffffff" />
        </LinearLayout>

        <!-- Progress Stats -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/meditationProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="本次修习"
                android:textSize="14sp"
                android:textColor="#999999"
                android:layout_marginEnd="16dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/totalMinutes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textColor="#8b7355"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="总分钟"
                    android:textSize="12sp"
                    android:textColor="#999" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="#ddd"
                android:layout_marginHorizontal="16dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/totalSessions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textColor="#8b7355"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="总次数"
                    android:textSize="12sp"
                    android:textColor="#999" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Bottom Section: Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:padding="16dp">

        <!-- Start Button -->
        <Button
            android:id="@+id/startCustomBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="开始修习"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/button_secondary"
            android:textColor="#ffffff"
            android:enabled="false"
            android:layout_marginBottom="12dp" />

        <!-- Stop Button (hidden initially) -->
        <Button
            android:id="@+id/stopMeditationBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="结束修习"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/button_danger"
            android:textColor="#ffffff"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
