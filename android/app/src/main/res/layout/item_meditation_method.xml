<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/method_card">

    <!-- Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/methodName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="数息观"
                android:textSize="18sp"
                android:textColor="#5a4a42"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/methodCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="专注类"
                    android:textSize="12sp"
                    android:textColor="#8b7355"
                    android:background="@drawable/category_tag"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/methodDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10 分钟"
                    android:textSize="12sp"
                    android:textColor="#999" />

                <TextView
                    android:id="@+id/methodDifficulty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="入门"
                    android:textSize="12sp"
                    android:textColor="#999"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnVideo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_video"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="播放视频"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnPin"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_pin_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="置顶"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Brief Description -->
    <TextView
        android:id="@+id/methodBrief"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="数呼吸次数，从 1 数到 10"
        android:textSize="14sp"
        android:textColor="#666"
        android:layout_marginTop="8dp" />

    <!-- Expanded Details -->
    <LinearLayout
        android:id="@+id/detailLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp"
        android:paddingTop="12dp"
        android:borderTop="1dp solid #f0ebe5"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📖 修习方法"
            android:textSize="14sp"
            android:textColor="#8b7355"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/methodDetailed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. 舒适坐姿..."
            android:textSize="14sp"
            android:textColor="#555"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💡 功效好处"
            android:textSize="14sp"
            android:textColor="#8b7355"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/methodBenefits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="培养专注力..."
            android:textSize="14sp"
            android:textColor="#555"
            android:background="@drawable/benefits_box"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnStartMethod"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="开始修习"
            android:textSize="15sp"
            android:background="@drawable/button_primary"
            android:textColor="#ffffff" />
    </LinearLayout>

</LinearLayout>
